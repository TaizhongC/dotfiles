<?xml version="1.0" encoding="UTF-8"?>
<actions>
<action>
	<icon>utilities-terminal</icon>
	<name>Open Terminal Here</name>
	<submenu></submenu>
	<unique-id>1783850092807396-1</unique-id>
	<command>exo-open --working-directory %f --launch TerminalEmulator</command>
	<description>Example for a custom action</description>
	<range></range>
	<patterns>*</patterns>
	<startup-notify/>
	<directories/>
</action>
<action>
	<icon>preferences-desktop-wallpaper</icon>
	<name>Set as Wallpaper</name>
	<submenu></submenu>
	<unique-id>1783850092807396-2</unique-id>
	<command>/home/tc/.local/bin/wallpaperctl set "%f"</command>
	<description>Set the selected image as the desktop wallpaper</description>
	<range></range>
	<patterns>*.jpg;*.jpeg;*.png;*.webp;*.gif</patterns>
	<startup-notify/>
	<image-files/>
</action>
