{
  "custom/audio-status": {
    "exec": "/home/tc/.config/waybar/scripts/audio-status",
    "return-type": "json",
    "interval": 1,
    "format": "{}",
    "on-click": "swaync-client -t -sw",
    "tooltip": false
  },
  "pulseaudio#microphone": {
    "format": "{format_source}",
    "format-source": "",
    "format-source-muted": ""
  },
  "pulseaudio/slider": {
    "min": 0,
    "max": 100,
    "orientation": "horizontal"
  }
}
