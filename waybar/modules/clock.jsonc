{
  "clock": {
    "timezone": "Europe/London",
    "format": "<span size='11pt'>{:%H:%M}</span>",
    "format-alt": "󰃱 <span size='11pt'>{:%H:%M  %A %d %B}</span>",
    "tooltip-format": "{calendar}",
    "calendar": {
      "format": {
        "today": "<span color='#88d1ec'><b>{}</b></span>"
      }
    }
  }
}
