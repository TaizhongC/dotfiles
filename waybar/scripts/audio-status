#!/bin/sh

state=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null) || exit 1
volume=$(printf '%s\n' "$state" | awk '{print $2}')

if printf '%s\n' "$state" | grep -q '\[MUTED\]' || awk "BEGIN { exit !($volume <= 0.005) }"; then
  icon='ó°ťź'
  class='muted'
elif awk "BEGIN { exit !($volume < 0.34) }"; then
  icon='ó°•ż'
  class='low'
elif awk "BEGIN { exit !($volume < 0.67) }"; then
  icon='ó°–€'
  class='medium'
else
  icon='ó°•ľ'
  class='high'
fi

printf '{"text":"%s","class":"%s"}\n' "$icon" "$class"
